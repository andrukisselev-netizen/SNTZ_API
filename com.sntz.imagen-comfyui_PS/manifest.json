{
  "manifestVersion": 5,
  "id": "com.sntz.imagen-comfyui",
  "name": "SNTZ",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "23.3.0"
  },
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "localFileSystem": "fullAccess"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "sntzPanel",
      "label": {
        "default": "SNTZ"
      },
      "description": {
        "default": "FLUX / Gemini generation via ComfyUI"
      },
      "minimumSize": {
        "width": 280,
        "height": 320
      },
      "maximumSize": {
        "width": 400,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 280,
        "height": 380
      },
      "preferredFloatingSize": {
        "width": 300,
        "height": 420
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-dark.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "darkest",
            "dark",
            "medium"
          ]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon-light.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "lightest",
            "light"
          ]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 48,
      "height": 48,
      "path": "icons/plugin.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "darkest",
        "dark",
        "medium",
        "lightest",
        "light",
        "all"
      ],
      "species": [
        "pluginList"
      ]
    }
  ]
}